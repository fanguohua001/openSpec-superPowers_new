<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.ApprovalInstanceMapper">

    <resultMap type="ApprovalInstance" id="ApprovalInstanceResult">
        <id property="instanceId" column="instance_id" />
        <result property="processId" column="process_id" />
        <result property="businessType" column="business_type" />
        <result property="businessId" column="business_id" />
        <result property="businessTitle" column="business_title" />
        <result property="starterUserId" column="starter_user_id" />
        <result property="currentNodeId" column="current_node_id" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectApprovalInstanceVo">
        select instance_id, process_id, business_type, business_id, business_title, starter_user_id,
               current_node_id, status, create_by, create_time, update_by, update_time, remark
        from approval_instance
    </sql>

    <select id="selectApprovalInstanceById" parameterType="Long" resultMap="ApprovalInstanceResult">
        <include refid="selectApprovalInstanceVo"/>
        where instance_id = #{instanceId}
    </select>

    <select id="selectApprovalInstanceByBusiness" resultMap="ApprovalInstanceResult">
        <include refid="selectApprovalInstanceVo"/>
        where business_type = #{businessType} and business_id = #{businessId}
        order by instance_id desc
        limit 1
    </select>

    <select id="selectApprovalInstanceList" parameterType="ApprovalInstance" resultMap="ApprovalInstanceResult">
        <include refid="selectApprovalInstanceVo"/>
        <where>
            <if test="starterUserId != null">and starter_user_id = #{starterUserId}</if>
            <if test="businessType != null and businessType != ''">and business_type = #{businessType}</if>
            <if test="businessTitle != null and businessTitle != ''">and business_title like concat('%', #{businessTitle}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by instance_id desc
    </select>

    <insert id="insertApprovalInstance" parameterType="ApprovalInstance" useGeneratedKeys="true" keyProperty="instanceId">
        insert into approval_instance(process_id, business_type, business_id, business_title, starter_user_id,
            current_node_id, status, create_by, create_time, remark)
        values(#{processId}, #{businessType}, #{businessId}, #{businessTitle}, #{starterUserId},
            #{currentNodeId}, #{status}, #{createBy}, sysdate(), #{remark})
    </insert>

    <update id="updateApprovalInstance" parameterType="ApprovalInstance">
        update approval_instance
        <set>
            <if test="currentNodeId != null">current_node_id = #{currentNodeId},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where instance_id = #{instanceId}
    </update>
</mapper>
